<script>
  function retainParamsToGroupsURL() {
    var currentUrl = new URL(window.location.href);
    var params = new URLSearchParams(currentUrl.search);
    var updatedParams = params.toString().replace(/\+/g, '%20');

    if (!params.toString()) {
      return;
    }

    var targetUrlFragment = 'groups.engine.com/new-trip';
    var allLinks = document.querySelectorAll('a');

    allLinks.forEach(function (link) {
      try {
        if (link.href.includes(targetUrlFragment)) {
          var linkUrl = new URL(link.href);
          link.href = linkUrl.origin + linkUrl.pathname + '?' + updatedParams;
        }
      } catch (error) {
      }
    });
  }

  window.addEventListener('DOMContentLoaded', retainParamsToGroupsURL);
</script>


<!-- Add current year to footer -->
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const yearTextElement = document.querySelector('[data-el="footer_year"]')

    if (yearTextElement) {
      const d = new Date();
      let year = d.getFullYear();
      yearTextElement.textContent = year
    }
  })
</script>



<!-- Speculation API for prefetching links -->
<script type="speculationrules">
  {
    "prefetch": [{
      "where": {
        "and": [
          { "href_matches": "/*" }
        ]
      },
      "eagerness": "moderate"
    }],
    "prerender": [{
      "where": {
        "and": [
          { "href_matches": "/sign-up" }
        ]
      },
      "eagerness": "moderate"
    }]
  }
</script>
