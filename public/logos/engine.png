<script>
"use strict";
(() => {
  // bin/live-reload.js

  // src/utils/splide.ts
  function mountSplide(selector, options) {
    const splideElements = document.querySelectorAll(selector);
    if (splideElements.length === 0) {
      console.warn(`Splide element not found for selector: ${selector}`);
      return [];
    }
    const splides = [];
    splideElements.forEach((splideElement) => {
      if (splideElement.classList.contains("is-initialized") || splideElement.getAttribute("data-initialized") === "true") {
        console.warn(`Splide already initialized for element:`, splideElement);
        return;
      }
      const splide = new Splide(splideElement, options).mount();
      splideElement.setAttribute("data-initialized", "true");
      splides.push(splide);
    });
    return splides;
  }

  // src/components/modular-slider/index.ts
  document.addEventListener("DOMContentLoaded", () => {
    mountSplide(".splide.is-modular-slider", {
      gap: "1.5rem",
      autoplay: false,
      autoWidth: true,
      omitEnd: true,
      flickPower: 200,
      speed: 600,
      wheel: false,
      drag: false,
      releaseWheel: false,
      dragMinThreshold: {
        mouse: 0,
        touch: 20
      },
      breakpoints: {
        991: {
          drag: true
        },
        762: {
          speed: 400
        }
      },
      flickMaxPages: 1,
      perMove: 1,
      easing: "cubic-bezier(.25, .46, .45, .94)",
      pagination: false,
      focus: 0
    });
  });
})();
