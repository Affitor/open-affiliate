<!-- Chatbot -->
<script type="text/javascript">
    function isAllowedTime() {
        const now = new Date();
        const currentHour = now.getUTCHours();
        const mountainTimeHour = (currentHour - 7 + 24) % 24; // Convert UTC to MT (UTC-7)
        return mountainTimeHour >= 6 && mountainTimeHour < 24; // Allow times between 6 AM and midnight MT
    }

    function initEmbeddedMessaging() {
        try {
            embeddedservice_bootstrap.settings.language = 'en_US'; // For example, enter 'en' or 'en-US'

            embeddedservice_bootstrap.init(
                '00D61000000Zy59',
                'MIAW_For_Web_Sales_Chat_Users',
                'https://hotelengine.my.site.com/ESWMIAWForWebSalesCha1701120415342',
                {
                    scrt2URL: 'https://hotelengine.my.salesforce-scrt.com'
                }
            );
        } catch (err) {
            console.error('Error loading Embedded Messaging: ', err);
        }
    };

    document.addEventListener('DOMContentLoaded', function () {
        if (isAllowedTime()) {
            const script = document.createElement('script');
            script.src = 'https://hotelengine.my.site.com/ESWMIAWForWebSalesCha1701120415342/assets/js/bootstrap.min.js';
            script.onload = initEmbeddedMessaging;
            document.body.appendChild(script);
        } else {
            console.log("Chat initialization skipped due to time restrictions.");
        }

        var chatLinks = document.querySelectorAll('.openchat');
        chatLinks.forEach(function (chatLink) {
            chatLink.addEventListener('click', function (event) {
                event.preventDefault(); // Prevent the default link action
                if (isAllowedTime()) {
                    launchChat();
                } else {
                    alert("Chat is not available from 12 AM to 6 AM MT.");
                }
            });
        });
    });

    function launchChat() {
        embeddedservice_bootstrap.utilAPI.launchChat()
            .then(() => {
                console.log('Inside Launch Chat');
            })
            .catch(() => {
                console.log('Inside Launch Chat catch Block');
            })
            .finally(() => {
                console.log('Inside Launch Chat finally Block');
            });
    }
</script>
<!-- End of Chatbot -->

<!-- Video player script -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const videoWrappers = document.querySelectorAll('[data="video-wrapper"]');

  videoWrappers.forEach(wrapper => {
    const overlay = wrapper.querySelector('[data="video-overlay"]');
    const closeBtn = wrapper.querySelector('[data="close"]');
    const video = wrapper.querySelector('[data="hero_video"]');

    const EscapePressed = () => {
      closeBtn.click();
      document.removeEventListener('keydown', OnEscapePressed);
    };
    const OnEscapePressed = (event) => event.key === 'Escape' && EscapePressed();

    overlay.addEventListener('click', () => {
      overlay.style.display = 'none';
      closeBtn.style.display = 'flex';
      video.play();
      document.addEventListener('keydown', OnEscapePressed);
    });

    closeBtn.addEventListener('click', () => {
      closeBtn.style.display = 'none';
      overlay.style.display = 'flex';
      video.pause();
    });
  });
});
</script>

<script defer>
  document.addEventListener("DOMContentLoaded", function() {
    const stats = document.querySelectorAll('.stats_card-number');
    const duration = 1000;

    const isInViewport = function(elem) {
      const bounding = elem.getBoundingClientRect();
      return (
        bounding.top >= 0 &&
        bounding.left >= 0 &&
        bounding.bottom <= (window.innerHeight || document.documentElement.clientHeight) &&
        bounding.right <= (window.innerWidth || document.documentElement.clientWidth)
      );
    };

    const animateValue = (element, start, end, duration, prefix, suffix, isDecimal) => {
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const currentValue = isDecimal
          ? (progress * (end - start) + start).toFixed(1)
          : Math.floor(progress * (end - start) + start);

        element.textContent = prefix + currentValue + suffix;

        if (progress < 1) {
          window.requestAnimationFrame(step);
        }
      };
      window.requestAnimationFrame(step);
    };

    const startAnimation = () => {
      stats.forEach(stat => {
        const content = stat.textContent.trim();

        // Extract prefix, number, suffix
        const match = content.match(/^([^\d.-]*)([\d.,]+)([^\d]*)$/);

        if (!match) return;

        const prefix = match[1] || "";
        const numberString = match[2].replace(/,/g, "");
        const suffix = match[3] || "";

        const number = parseFloat(numberString);
        const isDecimal = numberString.includes(".");

        if (isInViewport(stat) && !stat.classList.contains('animated')) {
          animateValue(stat, 0, number, duration, prefix, suffix, isDecimal);
          stat.classList.add('animated');
        }
      });
    };

    window.addEventListener('scroll', startAnimation);
    window.addEventListener('resize', startAnimation);

    startAnimation(); // Initial check
  });
</script>

