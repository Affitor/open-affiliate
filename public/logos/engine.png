  .navbar_logo.is-2 {
    display: none;
  }

  @media screen and (max-width: 1200px) and (min-width: 992px) {
    .navbar_logo.is-1 {
      display: none;
    }
    .navbar_logo.is-2 {
      display: block;
    }
