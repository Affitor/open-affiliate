  @media screen and (min-width: 992px) {
    .navbar_menu:has(.w--open) + .navbar_background-overlay {
      opacity: 1;
    }
  }
  
  .is-tooltip:hover::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 0.25rem);
    font-size: 0.75rem;
    color: white;
    background: var(--base-color-neutral--800);
    padding: 0 0.5rem;
    border-radius: 0.25rem;
    white-space: nowrap;
  }
    
  .navbar_component {
  	--background-color--background-tertiary: var(--base-color-neutral--800);
  }
    
	.navbar_component[data-theme="light"] {
    --background-color--background-secondary: #fff;
    --background-color--background-primary: var(--base-color-neutral--900);
    --background-color--background-tertiary: var(--base-color-neutral--50);
    --text-color--text-alternate-primary: var(--base-color-neutral--900);
    --text-color--text-alternate-secondary: var(--base-color-neutral--700);
    --text-color--text-primary: #fff;
  }
  
 	.navbar_component[data-theme="light"] .navbar_background-overlay {
    background-color: rgba(219, 211, 198, 0.6);
  }
  
  	.navbar_component[data-theme="white"] {
    --background-color--background-secondary: var(--base-color-neutral--white);
    --background-color--background-primary: var(--base-color-neutral--900);
    --background-color--background-tertiary: var(--base-color-neutral--50);
    --text-color--text-alternate-primary: var(--base-color-neutral--900);
    --text-color--text-alternate-secondary: var(--base-color-neutral--700);
    --text-color--text-primary: var(--base-color-neutral--white);
  }

    .navbar_component[data-theme="white"] .navbar_background-overlay {
    background-color: rgba(219, 211, 198, 0.3);
  }

  
  .navbar_component[data-theme="blue"] {
    --background-color--background-secondary: var(--base-color-blue--500);
    --background-color--background-tertiary: var(--base-color-blue--600);
    --text-color--text-alternate-secondary: var(--base-color-neutral--100);
    --text-color--text-alternate-primary: white;
  }
  
  .navbar_component[data-theme="blue"] .navbar_menu {
  	  --background-color--background-secondary: var(--base-color-blue--700);
  }

  .navbar_component[data-theme="blue"] .navbar_background-overlay {
    background-color: rgba(253, 75, 35, 0.6);
  }
  
  .navbar_component[data-theme="orange"] {
    --background-color--background-secondary: var(--base-color-orange--500);
    --background-color--background-tertiary: var(--base-color-orange--600);
    --text-color--text-alternate-secondary: var(--base-color-neutral--50);
    --text-color--text-alternate-primary: white;
    --base-color-blue--500: white;
  }
  
  .navbar_component[data-theme="orange"] .button {
  	background-color: var(--base-color-neutral--950);
    color: #fff;
  }
  
  .navbar_component[data-theme="orange"] .button:hover {
  	background-color: var(--base-color-neutral--900);
  }
  
  .navbar_component[data-theme="orange"] .navbar_menu {
  	  --background-color--background-secondary: var(--base-color-orange--700);
  }

  .navbar_component[data-theme="orange"] .navbar_background-overlay {
    background-color: rgba(253, 75, 35, 0.6);
  }
  
  .navbar_component[data-theme="yellow"] {
    --background-color--background-secondary: var(--base-color-yellow--500);
    --background-color--background-primary: var(--base-color-neutral--900);
    --background-color--background-tertiary: var(--base-color-yellow--600);
    --text-color--text-alternate-primary: var(--base-color-neutral--950);
    --text-color--text-alternate-secondary: var(--base-color-neutral--800);
    --text-color--text-primary: var(--base-color-neutral--50);
  }

  .navbar_component[data-theme="yellow"] .navbar_background-overlay {
    background-color: rgba(255, 178, 0, 0.6);
  }
  
    .navbar_component[data-theme="yellow"] .navbar_menu {
  	  --background-color--background-secondary: var(--base-color-yellow--200);
  }


  .navbar_component[data-theme="teal"] {
    --background-color--background-secondary: var(--base-color-teal--500);
    --background-color--background-primary: var(--base-color-neutral--900);
    --background-color--background-tertiary: var(--base-color-teal--600);
    --text-color--text-alternate-primary: var(--base-color-neutral--900);
    --text-color--text-alternate-secondary: var(--base-color-teal--900);
    --text-color--text-primary: var(--base-color-neutral--50);
  }

  .navbar_component[data-theme="teal"] .navbar_background-overlay {
    background-color: rgba(125, 203, 217, 0.6);
  }

  .navbar_component[data-theme="teal"] .navbar_background-overlay {
    background-color: rgba(125, 203, 217, 0.6);
  }
  
    .navbar_component[data-theme="teal"] .navbar_menu {
  	  --background-color--background-secondary: var(--base-color-teal--200);
  }

.banner_component:hover .green {
	background-color: var(--base-color-green--600);
}

.banner_component:hover .black {
	background-color: var(--base-color-neutral--900);
}

.banner_component:hover .blue {
	background-color: var(--base-color-blue--500);
}

